{
  "manifest_version": 3,
  "name": "Gwaka",
  "version": "0.9.0",
  "description": "Track time inside Google Apps Script editor with Gwaka",
  "icons": {
    "16": "icons/WakatimeIcon16.png",
    "48": "icons/WakatimeIcon48.png",
    "128": "icons/WakatimeIcon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon":  "icons/WakatimeIcon48.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "https://script.google.com/*",
        "https://docs.google.com/*",
        "https://drive.google.com/*",
        "https://colab.research.google.com/*",
        "https://sites.google.com/*"
      ],
      "js": ["content.js", "operatingSystems.js"]
    }
  ]
}